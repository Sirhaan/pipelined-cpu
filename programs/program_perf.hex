# program_perf.hex — Performance Benchmark
# A loop-heavy program to stress icache, dcache, and branch predictor.
#
# MIPS assembly equivalent:
#   LUI  $t0, 0
#   ORI  $t0, $t0, 100      # loop counter = 100
#   LUI  $t1, 0
#   ORI  $t1, $t1, 0        # accumulator = 0
#   LUI  $t2, 0
#   ORI  $t2, $t2, 4        # stride = 4 (byte offset)
#   LUI  $t3, 0
#   ORI  $t3, $t3, 0        # base address = 0x200
#   ADDI $t3, $t3, 512      #
#
# loop:
#   LW   $t4, 0($t3)        # load from memory
#   ADD  $t1, $t1, $t4      # accumulate
#   ADDI $t3, $t3, 4        # advance pointer
#   ADDI $t0, $t0, -1       # decrement counter
#   BEQ  $t0, $zero, done   # branch if counter == 0
#   BEQ  $zero, $zero, loop # unconditional back-branch
# done:
#   SW   $t1, 0($zero)      # store result
#   BREAK                    # signal end to testbench
#
# Encoding (hex, one word per line):
